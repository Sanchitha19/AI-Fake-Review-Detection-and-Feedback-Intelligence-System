# ─────────────────────────────────────────────────────────────────────────────
# AI Review Guard — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# API server settings
HOST=0.0.0.0
PORT=8000

# Bearer token for API authentication.
# Any client must send: Authorization: Bearer <this value>
# In dev mode (default below) auth is bypassed automatically.
API_SECRET_KEY=dev-secret-key-change-me

# Streamlit frontend → API base URL
API_BASE_URL=http://localhost:8000

# MLflow tracking URI (default: local ./mlruns folder)
MLFLOW_TRACKING_URI=./mlruns
